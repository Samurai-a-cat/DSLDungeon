@page "/"
@using System.Globalization
@using System.Linq
@using DSLDungeon.Services
@implements IDisposable
@inject GameService Game
@inject GameUiAgent UiAgent
@inject IJSRuntime JSRuntime

<div class="game-layout">
    
    <!-- ===== ВЕРХ: КАНВАС ===== -->
    <div class="main-game-area">
        <div class="canvas-container" id="skia-canvas-container">
            <SKCanvasView @ref="_canvasView" 
                          OnPaintSurface="OnPaintSurface" 
                          class="skia-canvas" />
            
            <!-- Управление -->
            <div class="controls-overlay">
                <div class="control-row">
                    <button class="btn @(Game.IsRunning ? "btn-active" : "")" 
                            @onclick="StartGame">
                        ▶ СТАРТ
                    </button>
                    <button class="btn @(!Game.IsRunning ? "btn-stop" : "")" 
                            @onclick="StopGame">
                        ■ СТОП
                    </button>
                    <button class="btn btn-restart" 
                            @onclick="RestartGame">
                        ↻ РЕСТАРТ
                    </button>
                </div>
                
                <div class="speed-control">
                    <span class="speed-label">⚡ @UiAgent.PendingSpeed.ToString("0.0", CultureInfo.InvariantCulture)x</span>
                    <input type="range" min="0" max="50" 
                           value="@((int)(UiAgent.PendingSpeed * 10))" 
                           @oninput="OnSpeedInput" 
                           class="speed-slider" />
                </div>
            </div>

            <!-- Инфо о дуэли -->
            <div class="duel-info">
                @if (UiAgent.Actors.Count >= 2)
                {
                    var hero = UiAgent.Actors.FirstOrDefault(a => a.Class == "hero-actor");
                    var orc = UiAgent.Actors.FirstOrDefault(a => a.Class == "orc-actor");
                    @if (hero != null && orc != null)
                    {
                        <div class="duel-bar">
                            <div class="fighter hero">
                                <span class="fighter-icon">♞</span>
                                <div class="hp-bar"><div class="hp-fill hero-hp" style="width:@(hero.HpPercent*100)%"></div></div>
                                <span class="fighter-name">@hero.Name</span>
                            </div>
                            <span class="vs">VS</span>
                            <div class="fighter orc">
                                <span class="fighter-icon">👹</span>
                                <div class="hp-bar"><div class="hp-fill orc-hp" style="width:@(orc.HpPercent*100)%"></div></div>
                                <span class="fighter-name">@orc.Name</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- ===== НИЗ: ЛОГИ + ИНСПЕКТОР ===== -->
    <div class="bottom-panel-wrapper">
        <div class="resize-handle"></div>
        <div class="bottom-panel">

            <!-- Логи -->
            <div class="panel log-panel">
                <div class="panel-header">
                    <span class="panel-title">📜 Хроника боя</span>
                    <button class="btn-clear" @onclick="ClearLogs">Очистить</button>
                </div>
                <div class="log-messages" @ref="_logContainer">
                    @foreach (var log in UiAgent.Logs)
                    {
                        <div class="@GetLogClass(log)">@log</div>
                    }
                </div>
            </div>

            <!-- Инспектор -->
            <div class="panel inspector-panel">
                <div class="panel-header">
                    <span class="panel-title">🔍 Инспектор</span>
                </div>
                <div class="inspector-content">
                    @foreach (var actor in UiAgent.Actors)
                    {
                        <div class="actor-card @(actor.Class)">
                            <div class="actor-card-header">
                                <span class="actor-emoji">@(actor.Class == "hero-actor" ? "♞" : "👹")</span>
                                <span class="actor-name">@actor.Name</span>
                            </div>
                            <div class="actor-stats">
                                <div class="stat-row">
                                    <span>HP</span>
                                    <div class="mini-hp-bar">
                                        <div class="mini-hp-fill" style="width:@(actor.HpPercent * 100)%"></div>
                                    </div>
                                    <span class="stat-value">@((actor.HpPercent * 100).ToString("0"))%</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private SKCanvasView? _canvasView;
    private ElementReference _logContainer;
    private DotNetObjectReference<GameViewport>? _selfReference;

    private double _panX, _panY, _zoom = 0.9;
    private double _viewportWidth = 800, _viewportHeight = 500;
    private bool _cameraCentered;

    private long _lastUiUpdateTicks;
    private int _lastLogCount;
    private bool _allowRender;

    private readonly TileSnapshot?[,] _tileGrid = new TileSnapshot[100, 100];
    private readonly SKPicture?[] _chunksWithText = new SKPicture?[100];
    private readonly SKPicture?[] _chunksNoText = new SKPicture?[100];
    private bool _chunksBaked;

    private readonly SKFont _fontCoords = new(SKTypeface.Default, 8f);
    private readonly SKFont _fontEmoji = new(SKTypeface.Default, 16f);
    private readonly SKFont _fontActorName = new(SKTypeface.Default, 9f);
    private readonly SKFont _fontParticle = new(SKTypeface.Default, 11f);

    private readonly SKPaint _paintGround = new() { Color = new SKColor(28, 52, 38), IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintWall = new() { Color = new SKColor(55, 40, 35), IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintGridStroke = new() { Color = new SKColor(38, 68, 48), IsAntialias = true, Style = SKPaintStyle.Stroke, StrokeWidth = 1f };
    private readonly SKPaint _paintCoordsText = new() { Color = new SKColor(70, 95, 78), IsAntialias = true, Style = SKPaintStyle.Fill };
    
    private readonly SKPaint _paintHeroHalo = new() { Color = new SKColor(255, 215, 0), IsAntialias = true, Style = SKPaintStyle.Stroke, StrokeWidth = 2.5f };
    private readonly SKPaint _paintOrcHalo = new() { Color = new SKColor(255, 80, 30), IsAntialias = true, Style = SKPaintStyle.Stroke, StrokeWidth = 2.5f };
    private readonly SKPaint _paintActorBg = new() { Color = new SKColor(0, 0, 0, 200), IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintActorEmoji = new() { IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintActorName = new() { Color = SKColors.White, IsAntialias = true, Style = SKPaintStyle.Fill };
    
    private readonly SKPaint _paintHpBg = new() { Color = new SKColor(60, 20, 20), Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintHpBarHero = new() { Color = new SKColor(0, 200, 100), Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintHpBarOrc = new() { Color = new SKColor(200, 60, 30), Style = SKPaintStyle.Fill };

    private readonly SKPaint _paintArrowHero = new() { Color = new SKColor(255, 215, 0, 180), IsAntialias = true, StrokeWidth = 2f, PathEffect = SKPathEffect.CreateDash([5f, 4f], 0) };
    private readonly SKPaint _paintArrowOrc = new() { Color = new SKColor(255, 80, 30, 180), IsAntialias = true, StrokeWidth = 2f, PathEffect = SKPathEffect.CreateDash([5f, 4f], 0) };
    private readonly SKPaint _paintAttackLine = new() { Color = new SKColor(255, 60, 60, 200), IsAntialias = true, StrokeWidth = 3f };

    private readonly SKPaint _paintParticleDmg = new() { Color = new SKColor(255, 80, 80), IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintParticleHeal = new() { Color = new SKColor(80, 255, 120), IsAntialias = true, Style = SKPaintStyle.Fill };
    private readonly SKPaint _paintParticleCrit = new() { Color = new SKColor(255, 200, 50), IsAntialias = true, Style = SKPaintStyle.Fill };

    private SKPath? _hexPath;
    private readonly Dictionary<string, float> _textWidthCache = new();

    protected override void OnInitialized()
    {
        InitializeHexPath();
        UiAgent.OnRenderTick += HandleRenderTick;
        UiAgent.OnLogChanged += HandleLogChanged;   // <-- добавить
    }
    
    private void HandleLogChanged()
    {
        _allowRender = true;
        InvokeAsync(StateHasChanged);
        InvokeAsync(async () => {
            await Task.Delay(50);
            await ScrollLogsToBottom();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        
        _selfReference = DotNetObjectReference.Create(this);
        
        await JSRuntime.InvokeVoidAsync("eval", @"
            window.gameViewport = {
                panX: 0, panY: 0, zoom: 0.9,
                
                init: function(canvasId, dotNetHelper, initialZoom) {
                    this.zoom = initialZoom;
                    const canvas = document.getElementById(canvasId);
                    if (!canvas) return;
                    
                    let isDragging = false, startX = 0, startY = 0;
                    
                    canvas.addEventListener('mousedown', e => {
                        isDragging = true;
                        startX = e.clientX - this.panX;
                        startY = e.clientY - this.panY;
                        canvas.style.cursor = 'grabbing';
                    });
                    
                    canvas.addEventListener('mousemove', e => {
                        if (!isDragging) return;
                        this.panX = e.clientX - startX;
                        this.panY = e.clientY - startY;
                        dotNetHelper.invokeMethodAsync('RequestInvalidate');
                    });
                    
                    window.addEventListener('mouseup', () => {
                        isDragging = false;
                        canvas.style.cursor = 'grab';
                    });
                    
                    canvas.addEventListener('wheel', e => {
                        e.preventDefault();
                        const rect = canvas.getBoundingClientRect();
                        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
                        const oldZoom = this.zoom;
                        const scale = Math.exp(-e.deltaY * 0.0012);
                        this.zoom = Math.max(0.15, Math.min(4.0, oldZoom * scale));
                        const s = this.zoom / oldZoom;
                        this.panX = mx - (mx - this.panX) * s;
                        this.panY = my - (my - this.panY) * s;
                        dotNetHelper.invokeMethodAsync('RequestInvalidate');
                    }, { passive: false });
                },
                
                getState: function() { return [this.panX, this.panY, this.zoom]; },
                setState: function(x, y, z) { this.panX = x; this.panY = y; this.zoom = z; }
            };
        ");

        await JSRuntime.InvokeVoidAsync("gameViewport.init", "skia-canvas-container", _selfReference, _zoom);
        await JSRuntime.InvokeVoidAsync("initPanelResize");
    }

    [JSInvokable] public void RequestInvalidate() => _canvasView?.Invalidate();

    private void HandleRenderTick()
    {
        if (!_cameraCentered && UiAgent.Actors.Count > 0)
        {
            CenterCamera();
            _cameraCentered = true;
        }
        _canvasView?.Invalidate();
    }

    private async Task ScrollLogsToBottom()
    {
        try {
            await JSRuntime.InvokeVoidAsync("eval", @"
                (function() {
                    var el = document.querySelector('.log-messages');
                    if (el) el.scrollTop = el.scrollHeight;
                })();
            ");
        } catch { }
    }

    private void CenterCamera()
    {
        var hero = UiAgent.Actors.FirstOrDefault(a => a.Class == "hero-actor");
        if (hero == null) return;
        
        _panX = (_viewportWidth / 2) - hero.PixelX * _zoom;
        _panY = (_viewportHeight / 2) - hero.PixelY * _zoom;
        
        JSRuntime.InvokeVoidAsync("gameViewport.setState", _panX, _panY, _zoom);
    }

    private void StartGame() { Game.Start(); RequestUiRender(); }
    private void StopGame() { Game.Stop(); RequestUiRender(); }
    
    private void RestartGame()
    {
        Game.Stop();
        JSRuntime.InvokeVoidAsync("location.reload");
    }
    
    private void ClearLogs() { RequestUiRender(); }

    private void OnSpeedInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var v))
            UiAgent.PendingSpeed = (float)(v / 10.0);
        RequestUiRender();
    }

    private void RequestUiRender() { _allowRender = true; StateHasChanged(); }
    protected override bool ShouldRender() { if (_allowRender) { _allowRender = false; return true; } return false; }

    private string GetLogClass(string log)
    {
        if (log.Contains("КРИТ")) return "log-entry log-crit";
        if (log.Contains("урона") || log.Contains("УРОН")) return "log-entry log-damage";
        if (log.Contains("Реген")) return "log-entry log-heal";
        if (log.Contains("Импульс")) return "log-entry log-impulse";
        if (log.Contains("движение") || log.Contains("путь")) return "log-entry log-move";
        if (log.Contains("ДУЭЛЬ")) return "log-entry log-duel";
        return "log-entry";
    }

    private void InitializeHexPath()
    {
        const float r = 36f;
        using var builder = new SKPathBuilder();
        
        for (int i = 0; i < 6; i++)
        {
            double a = Math.PI / 180 * (60 * i - 30);
            float x = (float)(r * Math.Cos(a));
            float y = (float)(r * Math.Sin(a));
            
            if (i == 0) builder.MoveTo(x, y);
            else builder.LineTo(x, y);
        }
        
        builder.Close();
        _hexPath = builder.Detach();
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        canvas.Clear(new SKColor(12, 12, 15));

        _viewportWidth = e.Info.Width;
        _viewportHeight = e.Info.Height;

        if (JSRuntime is IJSInProcessRuntime js)
        {
            var s = js.Invoke<double[]>("gameViewport.getState");
            if (s?.Length == 3) { _panX = s[0]; _panY = s[1]; _zoom = s[2]; }
        }

        canvas.Save();
        canvas.Translate((float)_panX, (float)_panY);
        canvas.Scale((float)_zoom);

        if (!_chunksBaked && UiAgent.AllCachedTiles.Count > 0) BakeChunks();

        float minX = (float)(-_panX / _zoom), maxX = (float)((_viewportWidth - _panX) / _zoom);
        float minY = (float)(-_panY / _zoom), maxY = (float)((_viewportHeight - _panY) / _zoom);
        float margin = 80f;

        // Chunks
        if (_chunksBaked)
        {
            bool showCoords = _zoom >= 0.5;
            var chunks = showCoords ? _chunksWithText : _chunksNoText;
            for (int cy = 0; cy < 10; cy++)
            {
                float y0 = 600f + 54f * (cy * 10) - margin, y1 = 600f + 54f * (cy * 10 + 9) + margin;
                if (y1 < minY || y0 > maxY) continue;
                for (int cx = 0; cx < 10; cx++)
                {
                    float x0 = 600f + 62.35f * (cx * 10) - margin, x1 = 600f + 62.35f * (cx * 10 + 9) + margin;
                    if (x1 < minX || x0 > maxX) continue;
                    var chunk = chunks[cx + cy * 10];
                    if (chunk != null) canvas.DrawPicture(chunk);
                }
            }
        }

        // Arrows
        foreach (var a in UiAgent.ActiveArrows)
        {
            var paint = a.ActorClass == "hero-actor" ? _paintArrowHero : _paintArrowOrc;
            canvas.DrawLine((float)a.StartX, (float)a.StartY, (float)a.TargetX, (float)a.TargetY, paint);
        }

        // Attacks
        foreach (var a in UiAgent.ActiveAttacks)
            canvas.DrawLine((float)a.StartX, (float)a.StartY, (float)a.TargetX, (float)a.TargetY, _paintAttackLine);

        // Actors
        foreach (var actor in UiAgent.Actors)
        {
            float ax = (float)actor.PixelX, ay = (float)actor.PixelY;
            if (ax < minX - margin || ax > maxX + margin || ay < minY - margin || ay > maxY + margin) continue;

            canvas.Save();
            canvas.Translate(ax, ay);

            bool isHero = actor.Class == "hero-actor";
            var halo = isHero ? _paintHeroHalo : _paintOrcHalo;
            var hpPaint = isHero ? _paintHpBarHero : _paintHpBarOrc;

            canvas.DrawCircle(0, -4, 16, _paintActorBg);
            canvas.DrawCircle(0, -4, 16, halo);

            DrawCenteredText(canvas, actor.Label, 0, 2, _fontEmoji, _paintActorEmoji);
            DrawCenteredText(canvas, actor.Name, 0, 22, _fontActorName, _paintActorName);

            canvas.DrawRect(-16, -26, 32, 4, _paintHpBg);
            canvas.DrawRect(-16, -26, 32 * actor.HpPercent, 4, hpPaint);

            canvas.Restore();
        }

        // Particles
        foreach (var p in UiAgent.ActiveParticles)
        {
            if (p.X < minX - margin || p.X > maxX + margin || p.Y < minY - margin || p.Y > maxY + margin) continue;
            var paint = p.ColorClass == "particle-heal" ? _paintParticleHeal : 
                        p.Text.Contains("КРИТ") ? _paintParticleCrit : _paintParticleDmg;
            paint.Color = paint.Color.WithAlpha((byte)(p.Opacity * 255));
            DrawCenteredText(canvas, p.Text, p.X, p.Y, _fontParticle, paint);
        }

        canvas.Restore();
    }

    private void BakeChunks()
    {
        var tiles = UiAgent.AllCachedTiles;
        for (int i = 0; i < tiles.Count; i++)
        {
            var t = tiles[i];
            int col = t.Q + (t.R / 2), row = t.R;
            if (col is >= 0 and < 100 && row is >= 0 and < 100) _tileGrid[col, row] = t;
        }

        for (int cy = 0; cy < 10; cy++)
            for (int cx = 0; cx < 10; cx++)
            {
                _chunksWithText[cx + cy * 10] = RecordChunk(cx * 10, cx * 10 + 9, cy * 10, cy * 10 + 9, true);
                _chunksNoText[cx + cy * 10] = RecordChunk(cx * 10, cx * 10 + 9, cy * 10, cy * 10 + 9, false);
            }
        _chunksBaked = true;
    }

    private SKPicture? RecordChunk(int c0, int c1, int r0, int r1, bool coords)
    {
        using var rec = new SKPictureRecorder();
        using var c = rec.BeginRecording(new SKRect(0, 0, 10000, 10000));
        for (int r = r0; r <= r1; r++)
            for (int col = c0; col <= c1; col++)
            {
                var t = _tileGrid[col, r];
                if (t == null) continue;
                c.Save();
                c.Translate((float)t.CenterX, (float)t.CenterY);
                c.DrawPath(_hexPath!, t.TerrainClass == "ground" ? _paintGround : _paintWall);
                c.DrawPath(_hexPath!, _paintGridStroke);
                if (coords)
                {
                    var txt = $"{t.Q},{t.R}";
                    c.DrawText(txt, new SKPoint(-txt.Length * 2.1f, 3), _fontCoords, _paintCoordsText);
                }
                c.Restore();
            }
        return rec.EndRecording();
    }

    private void DrawCenteredText(SKCanvas c, string text, float cx, float y, SKFont font, SKPaint paint)
    {
        if (!_textWidthCache.TryGetValue(text, out var w)) { w = font.MeasureText(text); _textWidthCache[text] = w; }
        c.DrawText(text, new SKPoint(cx, y), SKTextAlign.Center, font, paint);
    }

    public void Dispose()
    {
        UiAgent.OnRenderTick -= HandleRenderTick;
        UiAgent.OnLogChanged -= HandleLogChanged;
        _selfReference?.Dispose();
        _hexPath?.Dispose();
        foreach (var p in new[] { _paintGround, _paintWall, _paintGridStroke, _paintCoordsText, _paintHeroHalo, _paintOrcHalo, _paintActorBg, _paintActorEmoji, _paintActorName, _paintHpBg, _paintHpBarHero, _paintHpBarOrc, _paintArrowHero, _paintArrowOrc, _paintAttackLine, _paintParticleDmg, _paintParticleHeal, _paintParticleCrit })
            p.Dispose();
        foreach (var f in new[] { _fontCoords, _fontEmoji, _fontActorName, _fontParticle })
            f.Dispose();
        for (int i = 0; i < 100; i++) { _chunksWithText[i]?.Dispose(); _chunksNoText[i]?.Dispose(); }
    }
}