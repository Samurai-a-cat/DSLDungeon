@page "/game"
@using System.Globalization
@using DSLDungeon.Services
@implements IDisposable
@inject GameService Game

<div class="gothic-dashboard">
    @* ВЕРХНЯЯ СТАТУС-ПАНЕЛЬ *@
    <div class="dashboard-header">
        <div class="title-block">
            <h2>DUNGEON TACTICAL ORCHESTRATOR</h2>
            <div class="torch-indicator"></div>
            <span class="system-status">RUNES ACTIVE</span>
        </div>
        <div class="controls-block">
            <button class="btn btn-gothic btn-start" @onclick="StartGame">ACTIVATE RUNES</button>
            <button class="btn btn-gothic btn-stop" @onclick="StopGame">QUENCH SIMULATION</button>
        </div>
    </div>

    @* ОСНОВНОЙ КОНТЕНТ (Растянут на все доступное пространство) *@
    <div class="dashboard-body">

        @* ЛЕВАЯ КОЛОНКА: ТАКТИЧЕСКИЙ ЭКРАН С HP-БАРАМИ *@
        <div class="viewport-panel">
            <div class="panel-header">TACTICAL GRID (DRAG TO PAN, WHEEL TO ZOOM)</div>
            <div class="viewport-content">
                <svg class="hex-grid-svg"
                     viewBox="0 0 400 360"
                     @onwheel="OnWheel" @onwheel:preventDefault="true"
                     @onmousedown="OnMouseDown"
                     @onmousemove="OnMouseMove"
                     @onmouseup="OnMouseUp"
                     @onmouseleave="OnMouseLeave">

                    <g transform="translate(@(_panX.ToString("0.0", CultureInfo.InvariantCulture)), @(_panY.ToString("0.0", CultureInfo.InvariantCulture))) scale(@(_zoom.ToString("0.00", CultureInfo.InvariantCulture)))" style="transform-origin: center;">
                        @foreach (var tile in Game.UiAgent.MapTiles)
                        {
                            <g>
                                @* Рисуем сам гексагональный тайл *@
                                <polygon points="@tile.SvgPoints" class="hex-tile @tile.TerrainClass" />
            
                                @* Координаты гекса *@
                                <text>
                                    <text x="@tile.SvgCenterX" y="@tile.SvgCoordsY" class="hex-coords">
                                        @tile.Q,@tile.R
                                    </text>
                                </text>

                                @* Отрисовка персонажей *@
                                @if (!string.IsNullOrEmpty(tile.ActorLabel))
                                {
                                    @* Свечение под персонажем *@
                                    <circle cx="@tile.SvgCenterX" cy="@tile.SvgHaloY" r="12" class="actor-halo @tile.ActorClass" />
                
                                    @* Иконка персонажа *@
                                    <text>
                                        <text x="@tile.SvgCenterX" y="@tile.SvgIconY" class="actor-icon @tile.ActorClass">
                                            @tile.ActorLabel
                                        </text>
                                    </text>

                                    @* Прекрасно выровненный HP-Бар над головой *@
                                    <rect x="@tile.SvgHpX" y="@tile.SvgHpY" width="24" height="3" class="svg-hp-bg" />
                                    <rect x="@tile.SvgHpX" y="@tile.SvgHpY" width="@tile.SvgHpWidth" height="3" class="svg-hp-bar @tile.ActorClass" />
                                }
                            </g>
                        }
                    </g>
                </svg>
            </div>
        </div>

        @* ПРАВАЯ КОЛОНКА *@
        <div class="sidebar-panel">

            @* УПРАВЛЕНИЕ СКОРОСТЬЮ *@
            <div class="sub-panel speed-control">
                <div class="panel-header">TEMPORAL REGULATOR</div>
                <div class="speed-readout">
                    <span class="speed-value">@Game.UiAgent.PendingSpeed.ToString("0.0", CultureInfo.InvariantCulture)x</span>
                    <span class="speed-desc">SIMULATION RATE</span>
                </div>

                <input type="range"
                       min="0"
                       max="3"
                       step="0.1"
                       value="@LocalSpeedString"
                       @oninput="ChangeSpeed"
                       class="gothic-slider" />

                <div class="quick-speed-row">
                    <button class="btn btn-gothic-sm" @onclick="() => SetSpeed(0.0f)">PAUSE</button>
                    <button class="btn btn-gothic-sm" @onclick="() => SetSpeed(1.0f)">1.0x</button>
                    <button class="btn btn-gothic-sm" @onclick="() => SetSpeed(2.0f)">2.0x</button>
                </div>
            </div>

            @* РЕЕСТР СУЩЕСТВ *@
            <div class="sub-panel inspector">
                <div class="panel-header">CHRONICLE OF ENTITIES</div>
                <div class="inspector-list">
                    @foreach (var entity in Game.UiAgent.Entities)
                    {
                    <div @key="entity.Id" class="scifi-card @(entity.IsDead ? "dead" : "")">
                        <div class="card-title">
                            <span class="entity-icon">@(entity.Name.Contains("Рыцарь") ? "♞" : "👹")</span>
                            <span class="entity-name">@entity.Name</span>
                            <span class="entity-id">#@entity.Id.Index</span>
                        </div>
                        <div class="card-details">
                            <div>LOCATION: @entity.Position</div>
                            @if (entity.MaxHp > 0)
                            {
                            <div class="health-block">
                                <div class="health-numbers">VITALITY: @entity.CurrentHp / @entity.MaxHp</div>
                                <div class="gothic-progress-bg">
                                    <div class="gothic-progress-bar @(entity.IsDead ? "bar-dead" : "")"
                                         style="width: @(GetHpPercent(entity))%"></div>
                                </div>
                            </div>
                            }
                            else
                            {
                            <div class="status-destroyed">BANISHED TO ABYSS</div>
                            }
                        </div>
                    </div>
                    }
                </div>
            </div>

        </div>
    </div>

    @* НИЖНЯЯ ПАНЕЛЬ: ВСТРОЕННАЯ КОНСОЛЬ *@
    <div class="dashboard-console">
        <div class="panel-header">TACTICAL EVENTS ENGINE LOG</div>
        <div class="console-box" id="gothic-terminal">
            @* Используем обратный цикл в связке с flex-direction: column-reverse *@
            @for (int i = Game.UiAgent.Logs.Count - 1; i >= 0; i--)
            {
            <div class="log-line">@Game.UiAgent.Logs[i]</div>
            }
        </div>
    </div>
</div>

@code {
private double _zoom = 1.0;
private double _panX = 0;
private double _panY = 0;
private bool _isDragging = false;
private double _startX;
private double _startY;

private string LocalSpeedString => Game.UiAgent.PendingSpeed.ToString("0.0", CultureInfo.InvariantCulture);

protected override void OnInitialized()
{
Game.UiAgent.OnRenderTick += RefreshUi;
}

private void StartGame() => Game.Start();
private void StopGame() => Game.Stop();

private void RefreshUi()
{
InvokeAsync(StateHasChanged);
}

private int GetHpPercent(EntitySnapshot entity)
{
if (entity.MaxHp <= 0) return 0;
return (int)((float)entity.CurrentHp / entity.MaxHp * 100);
}

private void ChangeSpeed(ChangeEventArgs e)
{
if (float.TryParse(
e.Value?.ToString(),
NumberStyles.Any,
CultureInfo.InvariantCulture,
out var speed))
{
Game.UiAgent.PendingSpeed = speed;
}
}

private void SetSpeed(float speed)
{
Game.UiAgent.PendingSpeed = speed;
}

private void OnWheel(WheelEventArgs e)
{
double zoomFactor = e.DeltaY < 0 ? 1.1 : 0.9;
_zoom = Math.Clamp(_zoom * zoomFactor, 0.5, 4.0);
}

private void OnMouseDown(MouseEventArgs e)
{
if (e.Button == 0)
{
_isDragging = true;
_startX = e.ClientX;
_startY = e.ClientY;
}
}

private void OnMouseMove(MouseEventArgs e)
{
if (_isDragging)
{
double dx = e.ClientX - _startX;
double dy = e.ClientY - _startY;
_panX += dx;
_panY += dy;
_startX = e.ClientX;
_startY = e.ClientY;
}
}

private void OnMouseUp(MouseEventArgs e) => _isDragging = false;
private void OnMouseLeave(MouseEventArgs e) => _isDragging = false;

public void Dispose()
{
Game.UiAgent.OnRenderTick -= RefreshUi;
}
}

<style>
    .gothic-dashboard {
        --gothic-stone: #1a1613;
        --gothic-iron: #2d241e;
        --gothic-gold: #c59b27;
        --gothic-amber: #e5a93b;
        --gothic-blood: #8b1c1c;
        --gothic-abyss: #070605;
        --border-color: #3d342e;

        background-color: var(--gothic-abyss);
        color: #d1c7bd;
        font-family: 'Georgia', serif;
        padding: 15px;
        border-radius: 4px;
        border: 3px double var(--gothic-gold);

        /* Растягиваем весь дашборд по экрану */
        width: 100%;
        height: calc(100vh - 100px);
        box-sizing: border-box;

        display: flex;
        flex-direction: column;
        gap: 15px;
        user-select: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
    }

    /* ВЕРХНЯЯ ПАНЕЛЬ */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid var(--gothic-gold);
        padding-bottom: 10px;
    }
    .title-block {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .title-block h2 {
        color: var(--gothic-gold);
        margin: 0;
        font-size: 1.4rem;
        font-family: 'Times New Roman', serif;
        letter-spacing: 2px;
        text-shadow: 0 0 4px rgba(197, 155, 39, 0.4);
    }
    .torch-indicator {
        width: 10px;
        height: 10px;
        background-color: var(--gothic-amber);
        border-radius: 50%;
        box-shadow: 0 0 12px var(--gothic-amber), 0 0 4px var(--gothic-blood);
        animation: flicker 1.2s infinite;
    }
    .system-status {
        font-size: 0.8rem;
        color: var(--gothic-amber);
        font-style: italic;
    }

    /* КНОПКИ */
    .btn-gothic {
        background: var(--gothic-stone);
        border: 1px solid var(--gothic-gold);
        color: #d1c7bd;
        font-size: 0.85rem;
        font-family: 'Georgia', serif;
        padding: 6px 16px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-gothic:hover {
        background: var(--gothic-iron);
        color: var(--gothic-amber);
        border-color: var(--gothic-amber);
        box-shadow: 0 0 10px rgba(229, 169, 59, 0.2);
    }

    /* ТЕЛО СИМУЛЯТОРА (Растянуто по вертикали) */
    .dashboard-body {
        display: flex;
        gap: 15px;
        flex: 1; /* Ключевое свойство растяжки по высоте */
        min-height: 0;
        align-items: stretch;
    }

    /* КАРТА БОЯ */
    .viewport-panel {
        flex: 1.4;
        background: #0c0907;
        border: 1px solid var(--border-color);
        border-radius: 2px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .panel-header {
        background: var(--gothic-stone);
        padding: 6px 10px;
        font-size: 0.75rem;
        color: var(--gothic-gold);
        border-bottom: 1px solid var(--border-color);
        letter-spacing: 1px;
        font-weight: bold;
    }
    .viewport-content {
        padding: 5px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: radial-gradient(circle, #1a1411 0%, #050403 100%);
        flex: 1;
        overflow: hidden;
    }
    .hex-grid-svg {
        background-color: #0c0907 !important; /* Перебиваем дефолтный белый цвет SVG в браузере */
        max-width: 100%;
        max-height: 100%;
        cursor: grab;
        border-radius: 4px;
    }
    .hex-grid-svg:active {
        cursor: grabbing;
    }

    /* СТИЛИ ГЕКСОВ */
    .hex-tile {
        stroke: #2c221a !important;
        stroke-width: 1.5px !important;
        fill: #130f0d !important;
        transition: stroke 0.2s;
    }
    .hex-tile:hover {
        stroke: var(--gothic-amber) !important;
        cursor: pointer;
    }
    .hex-tile.ground { fill: #1c1511 !important; }
    .hex-tile.water { fill: #0b222b !important; stroke: #123e42 !important; }
    .hex-tile.wall { fill: #3a322a !important; stroke: #4e4035 !important; }
    .hex-tile.unbreakablewall { fill: #120d0a !important; stroke: #6b5123 !important; }
    .hex-tile.chasm { fill: #000000 !important; stroke: #140e0a !important; }

    .hex-coords {
        fill: #55443a !important;
        font-size: 6px;
        text-anchor: middle;
        pointer-events: none;
    }

    /* МИНИ HP-БАР НА КАРТЕ */
    .svg-hp-bg {
        fill: #2d0a0a;
        stroke: #0a0202;
        stroke-width: 0.3px;
    }
    .svg-hp-bar {
        transition: width 0.15s ease-out;
    }
    .svg-hp-bar.hero-actor { fill: #1ae514; } /* Зеленый бар ХП для героя */
    .svg-hp-bar.orc-actor { fill: #e51414; }  /* Красный бар ХП для орков */

    /* ПЕРСОНАЖИ НА КАРТЕ */
    .actor-halo {
        fill: none;
        stroke-width: 1.5px;
    }
    .actor-halo.hero-actor { stroke: var(--gothic-gold); }
    .actor-halo.orc-actor { stroke: var(--gothic-blood); }
    .actor-icon {
        font-size: 14px;
        text-anchor: middle;
        pointer-events: none;
    }
    .actor-icon.hero-actor { fill: var(--gothic-gold); }
    .actor-icon.orc-actor { fill: var(--gothic-blood); }

    /* БОКОВАЯ ПАНЕЛЬ */
    .sidebar-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .sub-panel {
        background: #110e0c;
        border: 1px solid var(--border-color);
        border-radius: 2px;
    }

    /* РЕГУЛЯТОР ВРЕМЕНИ */
    .speed-control {
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .speed-readout {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .speed-value {
        font-size: 1.4rem;
        color: var(--gothic-gold);
        font-weight: bold;
    }
    .speed-desc {
        font-size: 0.7rem;
        color: #83766c;
        font-style: italic;
    }
    .gothic-slider {
        width: 100%;
        accent-color: var(--gothic-gold);
        cursor: pointer;
    }
    .quick-speed-row {
        display: flex;
        gap: 5px;
    }
    .btn-gothic-sm {
        flex: 1;
        background: var(--gothic-stone);
        border: 1px solid var(--border-color);
        color: #a89a8f;
        font-size: 0.75rem;
        padding: 4px;
        cursor: pointer;
        font-family: 'Georgia', serif;
    }
    .btn-gothic-sm:hover {
        border-color: var(--gothic-gold);
        color: var(--gothic-gold);
    }

    /* РЕЕСТР СУЩЕСТВ */
    .inspector {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .inspector-list {
        padding: 10px;
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* КАРТОЧКА СУЩЕСТВА */
    .gothic-card {
        border: 1px solid var(--border-color);
        background: var(--gothic-stone);
        padding: 8px;
        border-radius: 2px;
        transition: opacity 0.3s;
    }
    .gothic-card.dead {
        opacity: 0.45;
        border-color: #531212;
        background: #1c0909;
    }
    .card-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 4px;
        margin-bottom: 6px;
    }
    .entity-icon {
        font-size: 1.1rem;
    }
    .entity-name {
        font-weight: bold;
        flex-grow: 1;
        margin-left: 8px;
        font-size: 0.85rem;
    }
    .entity-id {
        font-size: 0.7rem;
        color: #83766c;
    }
    .card-details {
        font-size: 0.75rem;
        color: #a89a8f;
    }

    /* ХП-БАР */
    .health-block {
        margin-top: 5px;
    }
    .health-numbers {
        margin-bottom: 2px;
    }
    .gothic-progress-bg {
        width: 100%;
        background-color: var(--gothic-abyss);
        border: 1px solid var(--border-color);
        height: 8px;
        overflow: hidden;
    }
    .gothic-progress-bar {
        height: 100%;
        background: var(--gothic-gold);
        transition: width 0.15s ease-out;
    }
    .gothic-progress-bar.bar-dead {
        background: var(--gothic-blood);
        width: 0% !important;
    }
    .status-destroyed {
        color: var(--gothic-blood);
        font-weight: bold;
        letter-spacing: 1px;
    }

    /* КОНСОЛЬ ЛОГОВ (Снизу вверх) */
    .dashboard-console {
        background: #110e0c;
        border: 1px solid var(--border-color);
        border-radius: 2px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .console-box {
        background: var(--gothic-abyss) !important;
        padding: 10px;
        height: 120px;
        max-height: 120px;
        overflow-y: auto;

        /* Ключевые свойства CSS для автопрокрутки снизу вверх */
        display: flex;
        flex-direction: column-reverse;

        font-size: 0.75rem;
        line-height: 1.3rem;
        color: var(--gothic-amber);
    }
    .log-line {
        border-bottom: 1px solid #16120f;
    }

    /* Кастомные готические скроллбары */
    ::-webkit-scrollbar {
        width: 6px;
    }
    ::-webkit-scrollbar-track {
        background: var(--gothic-abyss);
    }
    ::-webkit-scrollbar-thumb {
        background: var(--gothic-stone);
        border-radius: 3px;
        border: 1px solid var(--gothic-gold);
    }
    ::-webkit-scrollbar-thumb:hover {
        background: var(--gothic-gold);
    }

    /* АНИМАЦИИ */
    @@keyframes flicker {
        0% { opacity: 0.7; }
        50% { opacity: 1; }
        100% { opacity: 0.7; }
    }
</style>