@page "/game"
@using DSLDungeon.Game.Entities.Systems
@using DSLDungeon.Services
@implements IDisposable
@inject GameService Game

<h3>Dungeon Crawler (Прототип боя)</h3>

<div class="game-container">
    @* Выводим список всех существ на карте *@
    <div class="entity-list">
        <h4>Список существ:</h4>
        @foreach (var entity in Game.World.GetAllEntities())
        {
            <div class="entity-card @(entity.Health?.IsDead == true ? "dead" : "")">
                <strong>@entity.Name</strong> (ID: @entity.Id) <br/>
                Координаты: @entity.Position.ToString() <br/>
                @if (entity.Health != null)
                {
                    <span>XP: @entity.Health.CurrentHp / @entity.Health.MaxHp</span>
                    <div class="hp-bar" style="width: @(GetHpPercent(entity.Health))%"></div>
                }
            </div>
        }
    </div>
    
    <div class="speed-panel">
        <div class="speed-label">
            <strong>Скорость симуляции:</strong> @Game.GameSpeed.ToString("0.0")x
        </div>
        
        @* Ползунок для плавной регулировки от 0.0x до 3.0x *@
        <input type="range" 
               min="0" 
               max="3" 
               step="0.1" 
               value="@Game.GameSpeed" 
               @oninput="ChangeSpeed" 
               class="speed-slider" />

        @* Кнопки быстрого переключения *@
        <div class="quick-speed-buttons">
            <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetSpeed(0.0f)">Пауза</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetSpeed(1.0f)">1.0x (Норма)</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetSpeed(2.0f)">2.0x (Быстро)</button>
        </div>
    </div>

    @* Панель кнопок Старт/Стоп *@
    <div class="controls">
        <button class="btn btn-success" @onclick="StartGame">Старт игры</button>
        <button class="btn btn-danger" @onclick="StopGame">Выключить таймер</button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Подписываемся на событие обновления кадра игры
        Game.OnGameTick += RefreshUi;
    }

    private void StartGame()
    {
        Game.Start();
    }

    private void StopGame()
    {
        Game.Stop();
    }

    private void RefreshUi()
    {
        // Перерисовываем интерфейс Blazor в основном потоке браузера
        InvokeAsync(StateHasChanged);
    }

    private int GetHpPercent(HealthSystem health)
    {
        return (int)((float)health.CurrentHp / health.MaxHp * 100);
    }

    public void Dispose()
    {
        // Обязательно отписываемся при уничтожении компонента, чтобы не было утечек памяти
        Game.OnGameTick -= RefreshUi;
    }
    
    private void ChangeSpeed(ChangeEventArgs e)
    {
        if (float.TryParse(e.Value?.ToString(), out var speed))
        {
            Game.GameSpeed = speed;
        }
    }

    private void SetSpeed(float speed)
    {
        Game.GameSpeed = speed;
    }
}

<style>
    .game-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding: 10px;
    }
    .entity-card {
        border: 1px solid #ccc;
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 4px;
        background: #f9f9f9;
        width: 300px;
    }
    .entity-card.dead {
        background: #ffe6e6;
        opacity: 0.7;
    }
    .hp-bar {
        height: 8px;
        background: #4caf50;
        border-radius: 4px;
        transition: width 0.1s ease;
    }
    .controls {
        display: flex;
        gap: 10px;
    }
    .speed-panel {
        background: #f1f1f1;
        padding: 15px;
        border-radius: 6px;
        width: 300px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .speed-slider {
        width: 100%;
        cursor: pointer;
    }
    .quick-speed-buttons {
        display: flex;
        gap: 5px;
    }
</style>